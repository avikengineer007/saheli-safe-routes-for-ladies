datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String           @id @default(cuid())
  phone      String           @unique
  name       String
  ageGroup   String           // "under18" | "adult" | "elderly" — drives UI mode
  createdAt  DateTime         @default(now())
  contacts   TrustedContact[]
  journeys   Journey[]
  reports    IncidentReport[]
  trustScore Float            @default(0.5) // deterministic score: account age + clean report history
}

model TrustedContact {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  phone             String
  notifyOnSOS       Boolean @default(true)
  notifyOnDeviation Boolean @default(true)
}

model Journey {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  originLat    Float
  originLng    Float
  destLat      Float
  destLng      Float
  routeGeoJson Json
  startedAt    DateTime       @default(now())
  etaMinutes   Int
  status       String         // "active" | "completed" | "sos_triggered" | "abandoned"
  pings        LocationPing[]
}

model LocationPing {
  id        String   @id @default(cuid())
  journeyId String
  journey   Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  timestamp DateTime @default(now())
  onRoute   Boolean  // computed at write time, deterministic distance-to-line check
}

model IncidentReport {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat          Float
  lng          Float
  category     String   // "harassment" | "poor_lighting" | "unsafe_area" | "other"
  description  String?
  severityAuto String?  // LLM-assisted classification, advisory only
  status       String   @default("pending") // "pending" | "verified" | "rejected"
  createdAt    DateTime @default(now())
}

model SafetyScoreCache {
  id          String   @id @default(cuid())
  segmentHash String   @unique // hash of rounded lat/lng segment endpoints
  score       Float
  computedAt  DateTime @default(now())
}
